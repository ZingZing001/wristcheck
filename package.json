{
  "name": "wristcheck",
  "version": "0.1.0",
  "description": "Approve AI coding steps from iPhone, Apple Watch, or a browser fallback on your local network.",
  "type": "module",
  "bin": {
    "wristcheck": "./bin/wristcheck.js"
  },
  "scripts": {
    "setup": "node ./scripts/setup.js",
    "doctor": "node ./bin/wristcheck.js doctor",
    "autostart:install": "node ./scripts/autostart-install.js",
    "autostart:uninstall": "node ./scripts/autostart-uninstall.js",
    "start": "node ./bin/wristcheck.js serve",
    "test": "node --test"
  },
  "keywords": [
    "copilot",
    "ai",
    "approval",
    "iphone",
    "apple-watch",
    "watchos",
    "swiftui"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZingZing001/wristcheck.git"
  },
  "bugs": {
    "url": "https://github.com/ZingZing001/wristcheck/issues"
  },
  "homepage": "https://github.com/ZingZing001/wristcheck#readme",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  }
}
